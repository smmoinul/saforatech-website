{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/main.py" },
    { "src": "/(.*)",     "dest": "frontend/$1" }
  ],
  "env": {
    "ADMIN_SECRET": "@saforatech_admin_secret"
  }
}
